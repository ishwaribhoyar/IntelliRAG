# ============================================================
# IVERI LLM — Environment Configuration
# Copy this to .env and fill in real values.
# ============================================================

# ── App Environment ──────────────────────────────────────────
# Set to 'production' on Render/cloud to enable prod optimizations.
APP_ENV=development

# ── Logging ──────────────────────────────────────────────────
# DEBUG | INFO | WARNING | ERROR
LOG_LEVEL=INFO

# ── Universal LLM Router ─────────────────────────────────────
# Choose which LLM provider to use.
# Options: sarvam | openai | gemini | anthropic | groq | ollama | openrouter
LLM_PROVIDER=sarvam

# ── Sarvam (default provider) ────────────────────────────────
SARVAM_API_KEY=your-sarvam-api-key-here
SARVAM_API_URL=https://api.sarvam.ai/v1/chat/completions
SARVAM_MODEL_105B=sarvam-105b
SARVAM_MODEL_30B=sarvam-30b

# ── OpenAI (stub — set LLM_PROVIDER=openai to activate) ──────
# OPENAI_API_KEY=sk-...
# OPENAI_MODEL=gpt-4o-mini
# OPENAI_MODEL_5_NANO=gpt-5-nano

# ── Gemini (stub — set LLM_PROVIDER=gemini to activate) ──────
# GEMINI_API_KEY=AIza...
# GEMINI_MODEL=gemini-1.5-flash
# GEMINI_MODEL_FLASH_LITE=gemini-2.5-flash-lite
# GEMINI_MODEL_3_1_FLASH_LITE=gemini-3.1-flash-lite

# ── Jina Reranker (stub — fallback remote reranker) ──────────
# JINA_API_KEY=jina_...

# ── Anthropic (stub — set LLM_PROVIDER=anthropic) ────────────
# ANTHROPIC_API_KEY=sk-ant-...

# ── Groq (stub — set LLM_PROVIDER=groq) ─────────────────────
# GROQ_API_KEY=gsk_...

# ── Ollama (stub — set LLM_PROVIDER=ollama) ──────────────────
# OLLAMA_BASE_URL=http://localhost:11434
# OLLAMA_MODEL=llama3

# ── OpenRouter (stub — set LLM_PROVIDER=openrouter) ──────────
# OPENROUTER_API_KEY=sk-or-...

# ── LLM Tuning ───────────────────────────────────────────────
LLM_TEMPERATURE=0.2
LLM_REFRESH_TEMPERATURE=0.4
LLM_TIMEOUT_SECONDS=120
LLM_MAX_TOKENS_DEFAULT=8192
LLM_MAX_TOKENS_QUIZ=8192
LLM_MAX_TOKENS_MOCK=16384
LLM_MAX_TOKENS_SUMMARY=8192
LLM_MAX_TOKENS_ASK=8192
LLM_MAX_TOKENS_MENTOR=8192
LLM_MAX_TOKENS_ASK_USER_LIB=4096

# ── Pipeline Feature Flags ───────────────────────────────────
# Set to 'false' to disable a feature without code changes.
ENABLE_RERANKER=true
ENABLE_MMR=true
ENABLE_QUERY_EXPANSION=true

# ── Ingestion Workers ─────────────────────────────────────────
PIPELINE_MIN_WORKERS=1
PIPELINE_DEFAULT_WORKERS=3
PIPELINE_MAX_WORKERS=12
